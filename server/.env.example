# ====================================
# FactDropDaily - Environment Variables
# Copy this file to .env and fill in your real values
# ====================================

# --- Database ---
MONGODB_URI=your_mongodb_connection_string

# --- NewsAPI.org (free tier = 100 requests/day) ---
NEWSAPI_KEY=your_newsapi_key

# --- Blogger RSS source ---
BLOGGER_FEED=https://factdropdaily.blogspot.com/feeds/posts/default?alt=json

# --- Cloudinary (image hosting / caching, free tier) ---
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# --- Facebook Graph API ---
FB_PAGE_TOKEN=your_facebook_page_access_token
FB_PAGE_ID=your_facebook_page_id

# --- Email (Nodemailer + Gmail SMTP) ---
GMAIL_USER=your_gmail_address
GMAIL_PASS=your_gmail_app_password

# --- Admin Panel Auth ---
ADMIN_USERNAME=your_admin_username
ADMIN_PASSWORD=your_admin_password
JWT_SECRET=change_this_to_a_long_random_string

# --- Site ---
SITE_URL=https://factdropdaily.com
PORT=3000
NODE_ENV=production
